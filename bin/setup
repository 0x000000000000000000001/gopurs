#!/usr/bin/env bash

# Clones all core gopurs-* repositories as siblings of the gopurs directory.
# Useful for setting up the local development and testing environment.

ROOT_DIR=$(cd "$(dirname "$0")/.." && pwd)
SIBLING_DIR="$ROOT_DIR/.."

source "$(dirname "$0")/pkg"

echo "=> Cloning gopurs-* sibling repositories into $SIBLING_DIR..."

for pkg in "${CORE_PACKAGES[@]}"; do
  target="$SIBLING_DIR/gopurs-$pkg"
  if [ -d "$target" ]; then
    echo "[SKIP] gopurs-$pkg already exists."
  else
    echo "[CLONE] gopurs-$pkg..."
    git clone "https://github.com/0x000000000000000000001/gopurs-$pkg.git" "$target"
  fi
done

echo "=> Done! You can now run ./bin/test"
