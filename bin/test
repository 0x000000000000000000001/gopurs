#!/usr/bin/env bash

# Test runner for gopurs
# Compiles and runs PureScript passing tests.

ROOT_DIR=$(cd "$(dirname "$0")/.." && pwd)
TEST_DIR="$ROOT_DIR/tests"
PASSING_DIR="$TEST_DIR/passing"
RUNNER_DIR="$TEST_DIR/runner"

# Tests to skip (e.g. tests using experimental compiler features not supported by our purs version)
BLACKLIST=(
  # For versions > 0.15
  "DerivingClause.purs"
  "DerivingContravariant.purs"
  "DerivingFunctorFromBi.purs"
  "DerivingFunctorFromPro.purs"
  "DerivingProfunctor.purs"
  # Fails in Go/JS because of precise IEEE-754 serialization differences
  "NumberLiterals.purs"
  # Fails in Go because Go strings are UTF-8 and replace lone surrogates with U+FFFD
  "StringEdgeCases.purs"
  "StringEscapes.purs"
  # Tests 32-bit integer boundary overflow behavior which gopurs natively treats as 64-bit
  "2136.purs"
)

source "$(dirname "$0")/pkg"

for pkg in "${CORE_PACKAGES[@]}"; do
  if [ ! -d "$ROOT_DIR/../gopurs-$pkg" ]; then
    echo -e "\033[0;31m[ERROR]\033[0m Missing sibling checkout: gopurs-$pkg"
    echo "Please run ./bin/setup to clone all required repositories automatically."
    exit 1
  fi
done

mkdir -p "$RUNNER_DIR/src"

echo "Building gopurs compiler..."
cd "$ROOT_DIR"
npm run build --silent || { echo -e "\n\033[0;31m[FAILED]\033[0m gopurs build failed!"; exit 1; }

cd "$RUNNER_DIR"

if [ ! -f spago.yaml ]; then
  echo "package:" > spago.yaml
  echo "  name: runner" >> spago.yaml
  echo "  dependencies:" >> spago.yaml
  for pkg in "${CORE_PACKAGES[@]}"; do
    echo "    - $pkg" >> spago.yaml
  done
  echo "workspace:" >> spago.yaml
  echo "  packageSet:" >> spago.yaml
  echo "    registry: 77.10.1" >> spago.yaml
  echo "  extraPackages:" >> spago.yaml
  for pkg in "${CORE_PACKAGES[@]}"; do
    echo "    $pkg:" >> spago.yaml
    echo "      path: \"../../../gopurs-$pkg\"" >> spago.yaml
  done
fi

echo "Running tests from $PASSING_DIR..."

passed=0
failed=0

SKIP_BEFORE="NegativeBinder"
TEST_FILES=()
CLEAN_CACHE=0

if [ $# -gt 0 ]; then
  for arg in "$@"; do
    if [[ "$arg" == skip_before=* ]]; then
      SKIP_BEFORE="${arg#skip_before=}"
    elif [[ "$arg" == --skip-before=* ]]; then
      SKIP_BEFORE="${arg#--skip-before=}"
    elif [[ "$arg" == "-c" || "$arg" == "--clean" ]]; then
      CLEAN_CACHE=1
    else
      if [ -f "$ROOT_DIR/$arg" ]; then
        TEST_FILES+=("$ROOT_DIR/$arg")
      elif [ -f "$arg" ]; then
        TEST_FILES+=("$arg")
      elif [ -f "$PASSING_DIR/$arg" ]; then
        TEST_FILES+=("$PASSING_DIR/$arg")
      elif [ -f "$PASSING_DIR/$arg.purs" ]; then
        TEST_FILES+=("$PASSING_DIR/$arg.purs")
      else
        echo "Test file $arg not found."
      fi
    fi
  done
fi

if [ $CLEAN_CACHE -eq 1 ]; then
  echo "=> Cleaning Spago and output cache..."
  rm -rf .spago/* output-es/* output/*
fi

if [ ${#TEST_FILES[@]} -eq 0 ]; then
  TEST_FILES=("$PASSING_DIR"/*.purs)
fi

skipping_until=0
if [ -n "$SKIP_BEFORE" ] && [ ${#TEST_FILES[@]} -gt 1 ]; then
  skipping_until=1
fi

for test_file in "${TEST_FILES[@]}"; do
  test_name=$(basename "$test_file")
  
  if [ $skipping_until -eq 1 ]; then
    if [[ "$test_name" == "$SKIP_BEFORE" || "$test_name" == "$SKIP_BEFORE.purs" ]]; then
      skipping_until=0
    else
      continue
    fi
  fi
  
  # Check blacklist
  skip_test=0
  for b in "${BLACKLIST[@]}"; do
    if [ "$test_name" = "$b" ]; then
      skip_test=1
      break
    fi
  done
  
  if [ $skip_test -eq 1 ]; then
    echo "=> Skipping $test_name (blacklisted)"
    continue
  fi
  
  echo "=> Testing $test_name"
  
  rm -rf output/Main src/* output/Test* output/go.mod output/app
  
  cp "$test_file" "src/Main.purs"
  if [ -f "${test_file%.purs}.go" ]; then
    cp "${test_file%.purs}.go" "src/Main.go"
  fi
  if [ -f "${test_file%.purs}.js" ]; then
    cp "${test_file%.purs}.js" "src/Main.js"
  fi
  
  test_dir="${test_file%.purs}"
  if [ -d "$test_dir" ]; then
    cp -r "$test_dir"/* "src/"
  fi
  
  # Try to build with spago (just generating corefn)
  retry=0
  max_retries=2
  build_success=0
  while [ $retry -le $max_retries ]; do
    if out=$(spago build -q 2>&1); then
      build_success=1
      break
    fi
    retry=$((retry+1))
  done

  if [ $build_success -eq 1 ]; then
    # Generate Go code
    node ../../bin/gopurs.js --main Main
    
    if [ -d "output/Main" ] && [ -f "output/Main/Main.go" ]; then
      # Compile and Run Go code
      cd output
      rm -f go.mod
      go mod init gopurs/output > /dev/null 2>&1
      go mod tidy > /dev/null 2>&1
      
      if go build -o gopurs_main .; then
          output_run=$(./gopurs_main)
          exit_code=$?
          
          if [ -n "$output_run" ]; then
            echo "$output_run"
          fi
          
          if [ $exit_code -eq 0 ] && ! echo "$output_run" | grep -q "Fail"; then
            echo -e "   \033[0;32m[OK]\033[0m"
            passed=$((passed+1))
          else
            echo -e "   \033[0;31m[FAILED]\033[0m Execution error"
            failed=$((failed+1))
            break
          fi
      else
          echo -e "   \033[0;31m[FAILED]\033[0m Go Compilation error"
          failed=$((failed+1))
          break
      fi
      cd ..
    else
      echo -e "   \033[0;31m[FAILED]\033[0m gopurs did not generate Main.go"
      failed=$((failed+1))
      break
    fi
  else
    echo -e "   \033[0;31m[FAILED]\033[0m PureScript Compilation error"
    echo "$out"
    failed=$((failed+1))
    break
  fi
done

echo ""
if [ $failed -eq 0 ]; then
  echo -e "Summary: \033[0;32m$passed passed\033[0m, 0 failed."
else
  echo -e "Summary: \033[0;32m$passed passed\033[0m, \033[0;31m$failed failed\033[0m."
  exit 1
fi
